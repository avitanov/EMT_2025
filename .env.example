# Copy this file to .env and replace placeholders with environment-specific values.

POSTGRES_DB=write-your-database-name
POSTGRES_USER=write-your-database-username
POSTGRES_PASSWORD=write-your-database-password
POSTGRES_CONTAINER_PORT=write-your-postgres-container-port

BACKEND_PORT=write-your-local-backend-port
SERVER_PORT=write-your-backend-container-port
SPRING_APPLICATION_NAME=write-your-application-name
SPRING_DATASOURCE_URL=write-your-jdbc-url
SPRING_DATASOURCE_USERNAME=write-your-database-username
SPRING_DATASOURCE_PASSWORD=write-your-database-password
SPRING_JPA_HIBERNATE_DDL_AUTO=write-your-hibernate-ddl-mode
SPRING_JPA_HIBERNATE_SHOW_SQL=write-true-or-false
SPRING_JPA_SHOW_SQL=write-true-or-false
SPRING_JPA_FORMAT_SQL=write-true-or-false
APP_CORS_ALLOWED_ORIGINS=write-your-comma-separated-allowed-origins
APP_CORS_ALLOWED_METHODS=write-your-comma-separated-allowed-methods
APP_CORS_ALLOWED_HEADERS=write-your-comma-separated-allowed-headers
SIMILAR_PRODUCTS_PRICE_WINDOW=write-your-similar-products-price-window

GEMINI_API_KEY=write-your-api-key
GEMINI_MODEL=write-your-gemini-model

FRONTEND_PORT=write-your-local-frontend-port
FRONTEND_CONTAINER_PORT=write-your-frontend-container-port
VITE_API_BASE_URL=write-your-frontend-api-base-path
VITE_API_PROXY_TARGET=write-your-local-backend-url
BACKEND_INTERNAL_URL=write-your-backend-container-url

BACKEND_IMAGE_REPOSITORY=write-your-backend-image-repository
FRONTEND_IMAGE_REPOSITORY=write-your-frontend-image-repository
IMAGE_TAG=write-your-image-tag
COMPOSE_NETWORK_NAME=write-your-compose-network-name
POSTGRES_DATA_VOLUME_NAME=write-your-postgres-data-volume-name
